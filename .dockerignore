# Version control
.git
.gitignore

# Secrets / local env
.env
.env.*

# Python
__pycache__/
*.py[cod]
.venv/
venv/

# Node / frontend build artifacts (rebuilt inside the image)
frontend/node_modules/
frontend/dist/
node_modules/

# Runtime data (must not be baked into the image)
data/

